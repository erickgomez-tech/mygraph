{
  "name": "sap-b1-kg-ingestion",
  "version": "0.1.0",
  "description": "SAP B1 Service Layer ingestion into a JSON knowledge graph (BusinessPartners + Invoices)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postinstall": "npm run build",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "ingest": "ts-node-dev --transpile-only --once src/ingestion/run.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.15",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
